{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "Knot",
	"scopeName": "source.knot",
	"patterns": [
		{ "include": "#comments" },
		{ "include": "#strings" },
		{ "include": "#definitions" },
		{ "include": "#keywords" },
		{ "include": "#constants" },
		{ "include": "#types" },
		{ "include": "#numbers" },
		{ "include": "#decorators" },
		{ "include": "#field" },
		{ "include": "#operators" },
		{ "include": "#punctuation" },
		{ "include": "#identifiers" }
	],
	"repository": {
		"comments": {
			"patterns": [
				{
					"name": "comment.block.knot",
					"begin": "/\\*",
					"end": "\\*/",
					"captures": {
						"0": { "name": "punctuation.definition.comment.knot" }
					}
				},
				{
					"name": "comment.line.double-slash.knot",
					"begin": "//",
					"end": "$\\n?",
					"captures": {
						"0": { "name": "punctuation.definition.comment.knot" }
					}
				}
			]
		},
		"strings": {
			"patterns": [
				{
					"name": "string.quoted.double.knot",
					"begin": "\"",
					"end": "\"",
					"patterns": [
						{
							"name": "constant.character.escape.knot",
							"match": "\\\\[nrt\\\\\"{]"
						}
					]
				},
				{
					"name": "string.quoted.single.knot",
					"begin": "'",
					"end": "'"
				},
				{
					"name": "string.quoted.backtick.knot",
					"begin": "`",
					"end": "`"
				}
			]
		},
		"definitions": {
			"patterns": [
				{
					"match": "\\b(func)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
					"captures": {
						"1": { "name": "storage.type.function.knot" },
						"2": { "name": "entity.name.function.knot" }
					}
				},
				{
					"match": "\\b(class)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
					"captures": {
						"1": { "name": "storage.type.class.knot" },
						"2": { "name": "entity.name.type.class.knot" }
					}
				},
				{
					"match": "\\b(enum)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
					"captures": {
						"1": { "name": "storage.type.class.knot" },
						"2": { "name": "entity.name.type.enum.knot" }
					}
				}
			]
		},
		"field": {
			"patterns": [
				{
					"match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)(\\s*)(:)",
					"captures": {
						"1": { "name": "variable.other.member" },
						"3": { "name": "punctuation.separator.knot" }
					}
				},
				{
					"match": "\\b(this)(\\.)([a-zA-Z_][a-zA-Z0-9_]*)",
					"captures": {
						"1": { "name": "variable.language" },
						"2": { "name": "punctuation.accessor" },
						"3": { "name": "variable.other.property" }
					}
				}
			]
		},
		"decorators": {
			"patterns": [
				{
					"name": "storage.type.annotation.knot",
					"match": "@[a-zA-Z_][a-zA-Z0-9_]*"
				}
			]
		},
		"constants": {
			"patterns": [
				{
					"name": "constant.language.boolean.knot",
					"match": "\\b(true|false)\\b"
				},
				{
					"name": "constant.language.null.knot",
					"match": "\\bnull\\b"
				}
			]
		},
		"types": {
			"patterns": [
				{
					"name": "support.type.primitive.knot",
					"match": "\\b(I8|I16|I32|I64|U8|U16|U32|U64|F32|F64|String|Bool|Null|Void)\\b"
				}
			]
		},
		"numbers": {
			"patterns": [
				{
					"name": "constant.numeric.hex.knot",
					"match": "\\b0[xX][0-9a-fA-F][0-9a-fA-F_]*(i8|i16|i32|i64|u8|u16|u32|u64)\\b"
				},
				{
					"name": "constant.numeric.hex.knot",
					"match": "\\b0[xX][0-9a-fA-F][0-9a-fA-F_]*\\b"
				},
				{
					"name": "constant.numeric.binary.knot",
					"match": "\\b0[bB][01][01_]*(i8|i16|i32|i64|u8|u16|u32|u64)\\b"
				},
				{
					"name": "constant.numeric.binary.knot",
					"match": "\\b0[bB][01][01_]*\\b"
				},
				{
					"name": "constant.numeric.octal.knot",
					"match": "\\b0[oO][0-7][0-7_]*(i8|i16|i32|i64|u8|u16|u32|u64)\\b"
				},
				{
					"name": "constant.numeric.octal.knot",
					"match": "\\b0[oO][0-7][0-7_]*\\b"
				},
				{
					"name": "constant.numeric.float.knot",
					"match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*([eE][+-]?[0-9][0-9_]*)?(f32|f64)?\\b"
				},
				{
					"name": "constant.numeric.float.knot",
					"match": "\\b[0-9][0-9_]*[eE][+-]?[0-9][0-9_]*(f32|f64)?\\b"
				},
				{
					"name": "constant.numeric.integer.knot",
					"match": "\\b[0-9][0-9_]*(i8|i16|i32|i64|u8|u16|u32|u64)\\b"
				},
				{
					"name": "constant.numeric.integer.knot",
					"match": "\\b[0-9][0-9_]*\\b"
				}
			]
		},
		"keywords": {
			"patterns": [
				{
					"name": "storage.type.function.knot",
					"match": "\\bfunc\\b"
				},
				{
					"name": "storage.type.class.knot",
					"match": "\\b(class|enum)\\b"
				},
				{
					"name": "keyword.control.import.knot",
					"match": "\\bimport\\b"
				},
				{
					"name": "keyword.control.conditional.knot",
					"match": "\\b(if|else|match|in)\\b"
				},
				{
					"name": "keyword.control.loop.knot",
					"match": "\\b(for|while|break|continue)\\b"
				},
				{
					"name": "keyword.control.exception.knot",
					"match": "\\b(try|catch|throw)\\b"
				},
				{
					"name": "keyword.control.knot",
					"match": "\\b(return|assert|delete|new)\\b"
				},
				{
					"name": "storage.modifier.knot",
					"match": "\\b(abstract|static|private|operator)\\b"
				},
				{
					"name": "keyword.other.knot",
					"match": "\\b(as!?|args|kwargs|mixin|wrap|as)\\b"
				}
			]
		},
		"operators": {
			"patterns": [
				{
					"name": "keyword.operator.assignment.compound.knot",
					"match": "\\+=|-=|\\*=|/=|%=|&=|\\|=|\\^="
				},
				{
					"name": "keyword.operator.increment.knot",
					"match": "\\+\\+|--"
				},
				{
					"name": "keyword.operator.arrow.knot",
					"match": "->|=>"
				},
				{
					"name": "keyword.operator.comparison.knot",
					"match": "==|!=|<=|>="
				},
				{
					"name": "keyword.operator.logical.knot",
					"match": "&&|\\|\\|"
				},
				{
					"name": "keyword.operator.bitwise.shift.knot",
					"match": "<<|>>"
				},
				{
					"name": "keyword.operator.range.knot",
					"match": "\\.\\."
				},
				{
					"name": "keyword.operator.null-coalesce.knot",
					"match": "\\?\\?"
				},
				{
					"name": "keyword.operator.accessor.knot",
					"match": "::"
				},
				{
					"name": "keyword.operator.logical.knot",
					"match": "!"
				},
				{
					"name": "keyword.operator.arithmetic.knot",
					"match": "[+\\-*/%]"
				},
				{
					"name": "keyword.operator.bitwise.knot",
					"match": "[~&|^]"
				},
				{
					"name": "keyword.operator.assignment.knot",
					"match": "="
				},
				{
					"name": "keyword.operator.comparison.knot",
					"match": "[<>]"
				},
				{
					"name": "keyword.operator.accessor.knot",
					"match": "\\."
				},
				{
					"name": "keyword.operator.ternary.knot",
					"match": "\\?"
				}
			]
		},
		"punctuation": {
			"patterns": [
				{
					"name": "punctuation.separator.knot",
					"match": "[,:]"
				},
				{
					"name": "punctuation.section.knot",
					"match": "[()\\[\\]{}]"
				}
			]
		},
		"identifiers": {
			"patterns": [
				{
					"name": "variable",
					"match": "[a-zA-Z_][a-zA-Z0-9_]*"
				}
			]
		}
	}
}
